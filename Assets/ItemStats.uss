:root {
    font-size: 190%;
}

.fields {
    padding-top: 0;
    margin-bottom: 10px;
    margin-top: 10px;
    -unity-font-style: normal;
    color: rgb(255, 255, 255);
    font-size: 180%;
    padding-left: 10%;
}

.tittle {
    color: rgb(255, 255, 255);
    font-size: 190%;
    -unity-text-align: upper-left;
    justify-content: flex-start;
    align-items: auto;
    align-self: center;
    -unity-font-style: bold;
}
