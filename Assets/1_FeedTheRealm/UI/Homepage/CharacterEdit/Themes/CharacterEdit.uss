:root {
    --teal: rgb(110, 255, 251);
    --teal-dim: rgba(110, 255, 251, 0.18);
    --teal-strong: rgba(110, 255, 251, 0.32);
    --white: rgb(255, 255, 255);
    --white-soft: rgba(255, 255, 255, 0.78);
    --danger: rgb(255, 124, 124);
    --dark: rgba(0, 0, 0, 0.72);
    --darker: rgba(0, 0, 0, 0.84);
    --card-bg: rgba(0, 0, 0, 0.62);
    --radius: 12px;
    --radius-lg: 18px;
}

.body {
    flex-grow: 1;
    width: 100%;
    height: 100%;
    flex-direction: column;
}

.body-background {
    background-image: url("project://database/Assets/1_FeedTheRealm/VisualAssets/bg_feed.jpg?fileID=2800000&guid=8d8f8fd241019e57b9aee8d2035bd722&type=3#bg_feed");
    background-color: rgb(0, 0, 0);
    -unity-background-image-tint-color: rgb(110, 255, 251);
}

.character-edit-container {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    flex-direction: row;
    flex-wrap: nowrap;
    justify-content: space-between;
    align-items: stretch;
    align-content: flex-start;
    padding: 58px 16px 14px 16px;
    column-gap: 12px;
}

.character-panel,
.cosmetics-panel {
    background-color: var(--card-bg);
    border-width: 1px;
    border-color: rgba(110, 255, 251, 0.28);
    border-top-left-radius: var(--radius-lg);
    border-top-right-radius: var(--radius-lg);
    border-bottom-right-radius: var(--radius-lg);
    border-bottom-left-radius: var(--radius-lg);
    padding: 14px;
    height: 100%;
    min-height: 0;
}

.character-panel {
    flex-grow: 0;
    flex-shrink: 0;
    width: 31%;
    min-width: 300px;
    max-width: 380px;
    justify-content: flex-start;
    align-items: stretch;
}

.panel-title {
    color: var(--teal);
    font-size: 18px;
    letter-spacing: 1px;
    -unity-font-style: bold;
    margin-bottom: 8px;
    -unity-text-align: middle-left;
}

.panel-title-cosmetics {
    position: absolute;
    left: 16px;
    top: 12px;
    margin-bottom: 0;
}

.cosmetics-panel {
    flex-grow: 1;
    flex-shrink: 1;
    width: 69%;
    min-width: 0;
    align-items: center;
    justify-content: flex-start;
    padding-top: 42px;
}

.unity-text-field > #unity-text-input {
    border-top-left-radius: var(--radius);
    border-top-right-radius: var(--radius);
    border-bottom-right-radius: var(--radius);
    border-bottom-left-radius: var(--radius);
    background-image: none;
    background-color: var(--dark);
    color: var(--white);
    border-width: 1px;
    border-color: rgba(110, 255, 251, 0.3);
    white-space: normal;
    text-overflow: ellipsis;
    width: 100%;
}

.menu-text-input {
    border-top-left-radius: var(--radius);
    border-top-right-radius: var(--radius);
    border-bottom-right-radius: var(--radius);
    border-bottom-left-radius: var(--radius);
    background-color: rgba(0, 0, 0, 0);
    margin-bottom: 10px;
}

.text-input-full-width {
    width: 100%;
    min-height: 40px;
}

.bio-input {
    width: 100%;
    flex-grow: 0;
    min-height: 84px;
    max-height: 120px;
    -unity-text-align: upper-left;
}

.character-preview {
    width: 100%;
    max-width: 340px;
    min-height: 220px;
    max-height: 340px;
    aspect-ratio: 1;
    flex-grow: 0;
    align-self: center;
    margin: 4px 0 10px 0;
    background-color: var(--dark);
    border-width: 1px;
    border-color: rgba(110, 255, 251, 0.24);
    border-top-left-radius: var(--radius);
    border-top-right-radius: var(--radius);
    border-bottom-right-radius: var(--radius);
    border-bottom-left-radius: var(--radius);
}

.character-preview-background {
    background-image: url("project://database/Assets/GUI_Parts/Gui_parts/Frame_mid.png?fileID=2800000&guid=d5bda4f272648f34c8020e4e2772de3f&type=3#Frame_mid");
    -unity-background-image-tint-color: rgba(255, 255, 255, 0.8);
    -unity-background-scale-mode: stretch-to-fill;
}

.button-container {
    width: 100%;
    flex-grow: 0;
    flex-direction: row;
    justify-content: flex-end;
    align-items: center;
    column-gap: 10px;
    row-gap: 8px;
    flex-wrap: wrap;
    padding-right: 8px;
}

.action-button {
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    border-bottom-left-radius: 8px;
    min-width: 104px;
    height: 40px;
    padding-left: 14px;
    padding-right: 14px;
    border-width: 1px;
    border-color: rgba(110, 255, 251, 0.45);
    background-color: var(--teal-dim);
    color: var(--teal);
    font-size: 14px;
    -unity-font-style: bold;
}

.action-button:hover {
    background-color: var(--teal-strong);
    color: var(--white);
}

.cancel-button {
    border-color: rgba(255, 255, 255, 0.22);
    background-color: rgba(255, 255, 255, 0.07);
    color: var(--white-soft);
}

.cancel-button:hover {
    background-color: rgba(255, 255, 255, 0.12);
    color: var(--white);
}

.error-message {
    position: absolute;
    left: 16px;
    top: 10px;
    right: 16px;
    color: var(--danger);
    font-size: 14px;
    -unity-text-align: upper-left;
}

.hbar {
    flex-grow: 0;
    width: 94%;
    height: 1px;
    background-color: rgba(110, 255, 251, 0.2);
    align-self: center;
    margin-top: 6px;
    margin-bottom: 6px;
}

.content-container {
    width: 95%;
    background-color: var(--darker);
    border-width: 1px;
    border-color: rgba(110, 255, 251, 0.2);
    border-top-left-radius: var(--radius);
    border-top-right-radius: var(--radius);
    border-bottom-right-radius: var(--radius);
    border-bottom-left-radius: var(--radius);
    padding: 8px;
}

.content-container > #unity-content-and-vertical-scroll-container > #unity-content-viewport > #unity-content-container,
.content-container > .unity-scroll-view__content-container {
    flex-direction: row;
    flex-wrap: wrap;
    column-gap: 8px;
    row-gap: 8px;
    align-items: flex-start;
}

.content-categories {
    height: 94px;
    min-height: 94px;
    max-height: 94px;
}

.content-items {
    flex-grow: 1;
    min-height: 0;
}

.category_button,
.item_button {
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    border-bottom-right-radius: 10px;
    border-bottom-left-radius: 10px;
    border-width: 1px;
    border-color: rgba(110, 255, 251, 0.3);
    color: var(--white);
}

.category_button {
    width: 54px;
    min-width: 54px;
    height: 54px;
    min-height: 54px;
    background-color: rgba(110, 255, 251, 0.15);
}

.category_button:hover {
    background-color: rgba(110, 255, 251, 0.3);
}

.category_button > .unity-button__image {
    width: 130%;
    height: 130%;
    min-width: 130%;
    min-height: 130%;
    max-width: 130%;
    max-height: 130%;
}

.item_button {
    width: 84px;
    min-width: 84px;
    height: 84px;
    min-height: 84px;
    background-color: rgba(0, 0, 0, 0.45);
}

.item_button:hover {
    background-color: rgba(110, 255, 251, 0.22);
    border-color: rgba(110, 255, 251, 0.58);
}

.item_button > .unity-button__image {
    width: 90%;
}

.back-button {
    position: absolute;
    left: 16px;
    top: 16px;
    z-index: 2;
    width: 40px;
    height: 40px;
    border-width: 1px;
    border-color: rgba(110, 255, 251, 0.4);
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    border-bottom-left-radius: 8px;
    background-color: rgba(0, 0, 0, 0.25);
    color: var(--teal);
    -unity-text-align: middle-center;
}

.back-button:hover {
    background-color: var(--teal-dim);
    color: var(--white);
}

.back-button-background {
    background-image: none;
}
