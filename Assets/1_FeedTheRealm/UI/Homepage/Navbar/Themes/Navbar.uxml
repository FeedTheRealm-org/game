<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="Body" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0.6); height: 50px; width: 100%; min-height: 50px; max-height: 50px; flex-direction: row; justify-content: space-between; border-left-width: 10px; border-right-width: 10px; -unity-text-align: middle-center; color: rgb(255, 255, 255); -unity-font-style: bold; font-size: 10px; padding-left: 2%; padding-right: 2%;">
        <ui:Label text="Feed The Realm" name="FeedTheRealm" style="font-size: 16px;"/>
        <ui:Label text="Section Name Here" name="SectionLabel" style="font-size: 20px;"/>
        <ui:Button text="PlayerNameHere" name="ProfileButton" style="background-color: rgb(0, 0, 0); margin-bottom: 6px; margin-top: 6px;"/>
        <ui:Button text="💎 Gems" name="GemStoreButton" style="background-color: rgb(80, 40, 120); margin-bottom: 6px; margin-top: 6px; margin-right: 4px;"/>
    </ui:VisualElement>
</ui:UXML>
