    <ui:VisualElement name="Sidebar" class="sidebar">
        <ui:VisualElement name="CharacterData" class="character-data">
            <ui:Button name="CharacterIcon" class="character-icon"/>
            <ui:VisualElement name="DataContainer" class="character-stats">
                <ui:Label name="Username" text="MaxoGod" class="username"/>
                <ui:ProgressBar name="HealthBar" title="Health" value="100" class="stat-bar health"/>
                <ui:ProgressBar name="StaminaBar" title="Stamina" value="25" class="stat-bar stamina"/>
                <ui:VisualElement name="CurrencyContainer" class="currency">
                    <ui:Button name="GoldIcon" class="currency-icon"/>
                    <ui:Label name="GoldAmount" text="777" class="currency-amount"/>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:ScrollView name="CurrentQuestsContainer" class="quest-list" style="display: none;">
            <ui:VisualElement class="quest-item">
                <ui:Label text="Lorem ipsum Lorem ipsum Lorem ipsum Lorem ipsum Lorem ipsum Lorem ipsu" class="quest-title"/>
                <ui:ProgressBar title="0%" class="quest-progress"/>
            </ui:VisualElement>
            <ui:VisualElement class="quest-item">
                <ui:Label text="Lorem ipsum Lorem ipsum Lorem ipsum Lorem ipsum Lorem ipsum Lorem ipsu" class="quest-title"/>
                <ui:ProgressBar value="25" title="25%" class="quest-progress"/>
