:root {
}

#Body > #CharacterEditContainer > #Character > .unity-text-field > #unity-text-input {
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    border-bottom-right-radius: 10px;
    border-bottom-left-radius: 10px;
    background-image: none;
    -unity-background-image-tint-color: rgb(255, 255, 255);
    background-color: rgb(117, 113, 90);
    color: rgb(255, 255, 255);
    opacity: 1;
    -unity-text-align: upper-left;
    white-space: normal;
    text-overflow: ellipsis;
    justify-content: flex-start;
    align-self: flex-start;
    align-items: flex-start;
    width: 100%;
}

.menu-text-input {
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    border-bottom-right-radius: 10px;
    border-bottom-left-radius: 10px;
    overflow: visible;
    background-color: rgba(255, 255, 255, 0);
    -unity-background-scale-mode: stretch-to-fill;
    background-position-x: center;
    background-position-y: center;
    -unity-slice-type: sliced;
}

#Body > #CharacterEditContainer > #Cosmetics > #Categories > #Cancel > .unity-button__image {
    width: 50px;
    height: 50px;
    min-width: auto;
    min-height: auto;
}

#Body > #CharacterEditContainer > #Cosmetics > #Categories > #unity-content-and-vertical-scroll-container > #unity-content-viewport > #unity-content-container {
    flex-wrap: wrap;
    flex-direction: row;
}

#Body > #CharacterEditContainer > #Cosmetics > #Items > #unity-content-and-vertical-scroll-container > #unity-content-viewport > #unity-content-container {
    flex-wrap: wrap;
    flex-direction: row;
}

#Body > #CharacterEditContainer > #Cosmetics > #Items > .button > .unity-button__image {
    width: 100%;
    height: 100%;
    min-width: 100px;
    max-width: 100px;
    min-height: 100px;
    max-height: 100px;
}

#Body > #CharacterEditContainer > #Cosmetics > #Categories > .button > .unity-button__image {
    width: 200%;
    height: 200%;
    min-width: 200%;
    min-height: 200%;
    max-width: 200%;
    max-height: 200%;
}
