    <ui:VisualElement style="flex-grow: 1; background-image: url(&quot;project://database/Assets/GUI_Parts/Gui_parts/big_background.png?fileID=2800000&amp;guid=4edbc5539b441f049966c07e2ba12186&amp;type=3#big_background&quot;); width: auto; align-items: center; justify-content: center; background-size: 100% 100%; background-position-x: center; -unity-slice-scale: 1px; left: auto;">
